# Airbyte Environment Variables (Global/Shared)

# --- Platform ---
AIRBYTE_VERSION=2.0.1
LOG_LEVEL=INFO
MICRONAUT_ENVIRONMENTS=control-plane,oss,docker

# --- Database ---
