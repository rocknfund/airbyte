DATABASE_PORT=5432
DATABASE_DB=db-airbyte
DATABASE_USER=docker
DATABASE_PASSWORD=3900e5e60b8f4fb9d86008fa1d11ab93
DATABASE_URL=jdbc:postgresql://db:5432/db-airbyte?currentSchema=public

# --- Temporal ---
TEMPORAL_HOST=temporal:7233

# --- Internal APIs ---
INTERNAL_API_HOST=http://server:8001
WORKLOAD_API_HOST=http://workload-api-server:8007
